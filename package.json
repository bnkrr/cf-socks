{
  "name": "cf-socks",
  "version": "0.7.0",
  "description": "Cloudflare Worker backed TCP dialer with SOCKS5 and Go SDK clients",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "e2e:real": "tests/e2e/run.sh",
    "worker:bundle": "node worker/build.mjs",
    "worker:bundle-dashboard": "node worker/build.mjs --all",
    "worker:deploy:temporary": "wrangler deploy --temporary",
    "worker:dev": "wrangler dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
